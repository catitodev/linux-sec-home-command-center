# ============================================================
# Linux Security Home Command Center - .gitignore
# ============================================================

# ----------------------------------------------------------
# IDE & Editor files (NEVER share)
# ----------------------------------------------------------
.kiro/
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ----------------------------------------------------------
# Rust / Cargo
# ----------------------------------------------------------
/target/
**/*.rs.bk
# Note: Cargo.lock IS committed for binary projects (reproducible builds)

# ----------------------------------------------------------
# Node / Frontend (Svelte)
# ----------------------------------------------------------
node_modules/
dist/
build/
.svelte-kit/
.env
.env.*

# ----------------------------------------------------------
# OS files
# ----------------------------------------------------------
.DS_Store
Thumbs.db
*.desktop
.directory

# ----------------------------------------------------------
# Security sensitive files (NEVER commit)
# ----------------------------------------------------------
*.pem
*.key
*.p12
*.pfx
*.crt
*.csr
*.gpg
*.asc
!public-key.asc
secrets/
.secrets
*.secret
vault/
quarantine/

# ----------------------------------------------------------
# Database & local data
# ----------------------------------------------------------
*.db
*.db-journal
*.sqlite
*.sqlite3
data/
backups/

# ----------------------------------------------------------
# Logs
# ----------------------------------------------------------
*.log
logs/

# ----------------------------------------------------------
# Build artifacts & binaries
# ----------------------------------------------------------
*.o
*.so
*.dylib
*.exe
*.bin

# ----------------------------------------------------------
# Test & coverage
# ----------------------------------------------------------
coverage/
*.gcno
*.gcda
lcov.info
tarpaulin-report.html

# ----------------------------------------------------------
# Documentation build (internal only)
# ----------------------------------------------------------
docs/_build/
docs/internal/

# ----------------------------------------------------------
# Temporary files
# ----------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.orig

# ----------------------------------------------------------
# LLM models (too large for git)
# ----------------------------------------------------------
models/
*.gguf
*.bin
